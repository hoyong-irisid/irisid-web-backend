{
  "name": "irisid-monitoring",
  "version": "1.0.0",
  "private": true,
  "description": "Daily Iris ID website monitoring — links, forms, reports, GitHub issues",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "monitor": "tsx src/index.ts",
    "monitor:dry": "DRY_RUN=true tsx src/index.ts",
