# Site
SITE_URL=https://irisid.com
SITE_NAME=Iris ID

# Crawl limits (daily)
MAX_CRAWL_PAGES=80
CRAWL_DEPTH=2

# Playwright
HEADLESS=true

# GitHub Issues (repo: hoyong-irisid/monitoring)
GITHUB_TOKEN=
GITHUB_OWNER=hoyong-irisid
GITHUB_REPO=monitoring
GITHUB_ISSUES_ENABLED=true

# Resend daily report
RESEND_API_KEY=
REPORT_EMAIL_FROM=Iris ID Monitor <monitor@yourdomain.com>
REPORT_EMAIL_TO=ops@example.com

# Telegram (BotFather → token, @userinfobot → chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Form checks — set false to only validate fields without submit
FORM_SUBMIT_ENABLED=false
FORM_TEST_NAME=Monitoring Bot
FORM_TEST_EMAIL=monitoring+irisid@example.com
FORM_TEST_MESSAGE=Automated monitoring test — please ignore.

# Optional: open copy-fix PRs on WordPress/theme repo
WEBSITE_REPO_OWNER=
WEBSITE_REPO_NAME=
CONTENT_FIXES_ENABLED=false

# Dry run: no issues/email/telegram
DRY_RUN=false

# Cursor CLI (GitHub Actions agent-from-issue — secret only, not in .env for prod)
# CURSOR_API_KEY=
# CURSOR_AGENT_MODEL=composer-2.5
